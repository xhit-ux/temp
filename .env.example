# YMatrix / PostgreSQL 连接配置
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=mxadmin
DB_PASSWORD=your_password_here
DB_DATABASE=opc

# Go 后端 HTTP 服务相关
SERVER_HOST=localhost
SERVER_PORT=4048

# 批量写入器配置
# BATCH_SIZE: 每批次最多积攒的事件数，达到后立即触发一次数据库批量写入
# FLUSH_SECONDS: 最大等待秒数，即使未达到 BATCH_SIZE 也会强制 flush 一次积攒中的批次
BATCH_SIZE=500
FLUSH_SECONDS=5

# 内存通道队列容量
# QUEUE_CAPACITY: 普通写入通道的最大缓冲事件数（超过后发送方阻塞等待）
# PRIORITY_QUEUE_CAPACITY: 优先写入通道的最大缓冲事件数（用于异常/告警等需要优先持久化的事件）
QUEUE_CAPACITY=10000
PRIORITY_QUEUE_CAPACITY=2000

# 写入重试配置
# MAX_RETRIES: 单批次写入失败后的最大重试次数（超过则移入死信队列 DLQ）
# RETRY_BASE_DELAY_SECONDS: 重试退避的基础延迟秒数（指数退避: delay = base * 2^attempt）
MAX_RETRIES=5
RETRY_BASE_DELAY_SECONDS=1

# 死信队列（DLQ）配置
# DEAD_LETTER_DIR: 死信文件存储目录（写入失败超出重试次数的事件会序列化到该目录）
# DEAD_LETTER_REPLAY_INTERVAL_SECONDS: 死信重放扫描间隔（定期尝试将 DLQ 中的事件重新写入数据库）
# DEAD_LETTER_REPLAY_BATCH_SIZE: 每次重放扫描处理的最大事件数
DEAD_LETTER_DIR=data/dead-letter
DEAD_LETTER_REPLAY_INTERVAL_SECONDS=30
DEAD_LETTER_REPLAY_BATCH_SIZE=100

# 写入器协程池
# WRITER_POOL_SIZE: 普通写入 goroutine 数量（每个 goroutine 独立持有数据库连接和批次缓冲）
WRITER_POOL_SIZE=2