# YMatrix / PostgreSQL Connection
DB_HOST=192.168.126.135
DB_PORT=5432
DB_USERNAME=mxadmin
DB_PASSWORD=your_password_here
DB_DATABASE=opc

# Go Backend Server
SERVER_PORT=4048

# Batch Writer Configuration
BATCH_SIZE=500
FLUSH_SECONDS=5

# Queue Configuration
QUEUE_CAPACITY=10000
PRIORITY_QUEUE_CAPACITY=2000

# Retry Configuration
MAX_RETRIES=5
RETRY_BASE_DELAY_SECONDS=1

# Dead Letter Configuration
DEAD_LETTER_DIR=data/dead-letter
DEAD_LETTER_REPLAY_INTERVAL_SECONDS=30
DEAD_LETTER_REPLAY_BATCH_SIZE=100

# Writer Pool
WRITER_POOL_SIZE=2